//(3)
//Insertion at a Given Position in a Linked List

/*
class Node {
  public:
    int data;
    Node *next;
    Node(int x) {
        data = x;
        next = nullptr;
    }
};
*/

class Solution {
  public:
    Node *insertPos(Node *head, int pos, int val) {
        // code here
        if (pos==1){
            Node *newNode = new Node(val);
            newNode->next = head;
            return newNode;
    }
    if (head == NULL) return NULL;
    head->next = insertPos(head->next,pos-1,val);
    return head;
    }
};



//(4)
//Delete in a Singly Linked List


/*
class Node {
public:
    int data;
    Node* next;
    Node(int data) {
        this->data = data;
        this->next = nullptr;
    }
};
*/
class Solution {
  public:
    Node* deleteNode(Node* head, int x) {
        if (head == NULL)
            return NULL;
        if (x == 1) {
            Node* temp = head;
            head = head->next;
            delete temp;
            return head;
        }
        head->next = deleteNode(head->next, x - 1);
        return head;
    }
};



