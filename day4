//(6)
//Deletion at the end of a Linked Lis

/*
class Node {
public:
    int data;
    Node* next;

    Node(int x) {
        data = x;
        next = NULL;
    }
};
*/
class Solution {
  public:
    Node* removeLastNode(Node* head) {
        if(head->next == NULL) {
            delete head;
            return NULL;
        }
        if(head->next->next == NULL) {
            delete head->next;
            head->next = NULL;
            return head;
        }
        head->next = removeLastNode(head->next);
        return head;
    }
};




