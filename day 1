#include <bits/stdc++.h>
using namespace std;

void print() {
    for(int i = 4; i >= 1; i--) {
        for(int j = 0; j < i; j++) {
            cout << "*";
        }
        cout << endl;
    }
}

int main() {
    print();
    return 0;
}

