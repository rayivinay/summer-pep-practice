//(1)
//Right Triangle Star Pattern
#include <bits/stdc++.h>
using namespace std;

void print() {
    for(int i = 1; i <= 4; i++) {
        for(int j = 1; j <= i; j++) {
            cout << "*";
        }
        cout << endl;
    }
}

int main() {
    print();
    return 0;
}

//(2)
//Inverted Right Triangle Star Pattern

#include <bits/stdc++.h>
using namespace std;

void print() {
    for(int i = 4; i >= 1; i--) {
        for(int j = 0; j < i; j++) {
            cout << "*";
        }
        cout << endl;
    }
}

int main() {
    print();
    return 0;
}

//(3)
//Number Triangle Pattern

#include <bits/stdc++.h>
using namespace std;

void print() {
    int num = 1;

    for(int i = 1; i <= 4; i++) {
        for(int j = 0; j < i; j++) {
            cout << num << " ";
            num++;
        }
        cout << endl;
    }
}

int main() {
    print();
    return 0;
}

//(4)
//GCD of Two Numbers using Euclidean Algorithm


#include <bits/stdc++.h>
using namespace std;

int gcd(int a,int b){
    while(b!=0){
        int rem = a%b;
        a = b;
        b = rem;
    }
    return a;
}
int main(){
    cout<<gcd(12,8);
}

