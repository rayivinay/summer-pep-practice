//(7)
// Sum of First N Natural Numbers using Recursion
#include <bits/stdc++.h>
using namespace std;
int sum(int n){
    if(n == 1){
        return 1;
    }
    return n + sum(n-1);
}
int main() {
    cout<<sum(3);
}

// (8)
//Factorial of a Number using Recursion

#include <bits/stdc++.h>
using namespace std;
int mul(int n){
    if(n == 1){
        return 1;
    }
    return n * mul(n-1);
}
int main() {
    cout<<mul(5);
}


