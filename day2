//(8)
//binry search
#include <iostream>
#include<vector>
using namespace std;
int bs (vector<int>v,int t){
    int s=0, e=v.size()-1;
    while(s<=e){
       int mid = (s+e)/2;
        if(v[mid]==t) return mid;
        else if(v[mid]>t) e=mid-1;
        else s=mid+1;
    }
}
int main(){
    vector<int> v = {1,2,3,4,5,6,7,8};
    int t = 7;
    cout<<bs(v,t);
}
